{
  "name": "ecommerce-ai-assistant",
  "version": "1.0.0",
  "description": "ecommerce ai assistant",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "test": "vitest run",
