    "pinia": "^2.1.7",
    "vue": "^3.4.21",
    "vue-router": "^4.3.0"
  },
  "devDependencies": {
    "@tauri-apps/api": "^2.10.1",
    "@tauri-apps/cli": "^2.10.1",
    "@types/papaparse": "^5.5.2",
    "@vitejs/plugin-vue": "^6.0.6",
    "esbuild": "^0.28.0",
    "jsdom": "^29.0.2",
    "typescript": "^5.4.2",
    "unplugin-auto-import": "^21.0.0",
    "unplugin-vue-components": "^32.0.0",
    "vite": "^8.0.9",
    "vitest": "^4.1.5",
    "vue-tsc": "^2.0.6"
